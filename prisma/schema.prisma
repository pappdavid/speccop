// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // In Prisma 7, the database URL is configured in prisma.config.ts
  // rather than directly in the schema. For PrismaClient, the URL is
  // provided via the DATABASE_URL environment variable through the
  // PrismaPg adapter in lib/db.ts.
  provider = "postgresql"
}

// ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  complianceChecks  ComplianceCheck[]
  integrations      Integration[]
  stripeCustomerId  String?           @unique
  subscriptionTier  SubscriptionTier  @default(FREE)
  checksThisMonth   Int               @default(0)
  checksResetAt     DateTime          @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ────────────────────────────────────────────────────────

model Integration {
  id          String          @id @default(cuid())
  userId      String
  type        IntegrationType
  accessToken String          @db.Text
  refreshToken String?        @db.Text
  expiresAt   DateTime?
  workspaceId String?
  workspaceName String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model ComplianceCheck {
  id              String        @id @default(cuid())
  userId          String
  ticketId        String
  ticketUrl       String?
  ticketTitle     String
  ticketBody      String        @db.Text
  prNumber        Int
  prUrl           String
  prTitle         String
  prBody          String?       @db.Text
  prDiff          String?       @db.Text
  repoOwner       String
  repoName        String
  status          CheckStatus   @default(PENDING)
  report          Json?
  scopeCreepScore Int?
  githubCommentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  PRO
  TEAM
}

enum IntegrationType {
  LINEAR
  JIRA
}

enum CheckStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
